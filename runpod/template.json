{
  "name": "wan-comfyui",
  "type": "pod",
  "recommended_image": "ghcr.io/grawthings-beep/wan:cuda12.8",
  "http_ports": "8188",
  "tcp_ports": "",
  "container_disk_gb": 40,
  "volume_mount_path": "/workspace",
  "recommended_volume_gb": 200,
  "docker_command": "",
  "environment": {
    "MODEL_PROFILE": "gguf",
    "DOWNLOAD_MODELS": "1",
    "INSTALL_CUSTOM_NODES": "0",
    "USE_BAKED_CUSTOM_NODES": "1",
    "INSTALL_SYSTEM_DEPS": "0",
    "INSTALL_QWENVL_GGUF_DEPS": "0",
    "START_RUNPOD_SERVICES": "0",
    "WORKSPACE_DIR": "/workspace/comfyui",
    "MODEL_ROOT": "/workspace/comfyui",
    "LISTEN": "0.0.0.0",
    "PORT": "8188",
    "COMFYUI_ARGS": "--reserve-vram 3"
  },
  "manual_model_note": "Place Civitai Wan diffusion models in /workspace/ComfyUI/models/unet for GGUF or /workspace/ComfyUI/models/diffusion_models for FP8."
}
